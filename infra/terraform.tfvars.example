# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is in .gitignore — never commit it.

aws_region  = "us-east-1"
app_name    = "hatfield-financial"
domain_name = "hatfield-financial.com"
db_username = "name"
db_password = "password"
secret_key  = "idkGoodLuckGuesing!"

# Shared secret for internal Lambda → backend calls (Custom ETF auto-rebalance).
# Generate with: openssl rand -hex 32
internal_api_secret = "replace-me-with-a-long-random-hex-string"
