# ── Backend ───────────────────────────────────────────────────────────────────
# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Database — PostgreSQL in cloud, SQLite used automatically when unset locally
DATABASE_URL=postgresql://hatfield:yourpassword@your-rds-host:5432/hatfield

# Allowed CORS origin — set to your CloudFront domain after terraform apply
ALLOWED_ORIGIN=https://CHANGE_ME.cloudfront.net

# ── Frontend (set in GitHub Actions secrets, not in .env) ────────────────────
# Full URL of the ALB — output by terraform as alb_dns_name
REACT_APP_API_URL=https://CHANGE_ME.us-east-1.elb.amazonaws.com
